            {
              "id": "topic-2",
              "title": "行针与得气",
              "subTopics": [
                {
                  "id": "subtopic-auto-0",
                  "title": "未分类",
                  "knowledgePoints": [
                    {
                      "type": "qa",
                      "years": [
                        2020
                      ],
                      "question": "名词解释：刺手",
                      "answer": "在中医针灸中，刺手是指医者持针施术的手，主要负责掌握针具并实施手法操作。具体来说，刺手在进针时运用指力、腕臂力于针尖，快速刺入皮肤，行针时便于左右捻转、上下提插和实施补泻以及出针时的手法操作等?",
                      "options": [],
                      "explanation": null,
                      "tags": [
                        {
                          "term": "腕",
                          "category": "acupoints"
                        },
                        {
                          "term": "指",
                          "category": "acupoints"
                        }
                      ],
                      "id": "item-464"
                    },
                    {
                      "type": "qa",
                      "years": [
                        2015
                      ],
                      "question": "名词解释：押手",
                      "answer": "一般将医者持针的右手称为 ＂ 刺手 ” ，按压穴位局部的左手称为 ＂ 押手 ＂ 。押手的作用主要是固定穴位的皮肤，使毫针能够准确地刺入榆穴，并能减少进针时的疼痛；对千长针可使针身有所依靠，不致摇晃和弯曲。进针时， 刺手和押手配合得当，动作协调，可以减轻痛感，行针顺利，并能调整和加强针感，提高治疗效果。灸法",
                      "options": [],
                      "explanation": null,
                      "tags": [],
                      "id": "item-465"
                    },
                    {
                      "type": "qa",
                      "years": [
                        2012,
                        2013
                      ],
                      "question": "14名词解释：行针",
                      "answer": "为了使患者产生针刺的感应而行使一定的手法，称之为行针。",
                      "options": [],
                      "explanation": null,
                      "tags": [],
                      "id": "item-466"
                    },
                    {
                      "type": "qa",
                      "years": [
                        2009,
                        2011,
                        2012,
                        2013,
                        2015,
                        2017
                      ],
                      "question": "18名词解释：得气",
                      "answer": "针刺部位产生酸、麻、胀、重等反应，而医者指下亦有一种沉紧的感觉，称为得气，也称针感。 一般得气迅速，效果较好，得气迟钝，效果较差。得气快慢或不得气，与患者病情和体质，取穴准确，针刺的深浅和角度等有密切关系，其针感性质、传导方向，也常与穴位部位有关。",
                      "options": [],
                      "explanation": null,
                      "tags": [
                        {
                          "term": "指",
                          "category": "acupoints"
                        }
                      ],
                      "id": "item-467"
                    },
                    {
                      "type": "qa",
                      "years": [
                        2020
                      ],
                      "question": "下列哪些是行针的辅助手法（震颤法、弹法、提插法、捻转法）；",
                      "answer": "震颤法，其他选项是基本手法",
                      "options": [],
                      "explanation": null,
                      "tags": [],
                      "id": "item-468"
                    }
                  ]
                }
