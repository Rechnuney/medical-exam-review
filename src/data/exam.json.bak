          "title": "毫针刺法",
          "topics": [
            {
              "id": "topic-auto-0",
              "title": "未分类",
              "subTopics": [
                {
                  "id": "subtopic-auto-0",
                  "title": "未分类",
                  "knowledgePoints": [
                    {
                      "type": "text",
                      "content": "进针方法",
                      "tags": [],
                      "id": "item-455"
                    },
                    {
                      "type": "qa",
                      "years": [
                        2012
                      ],
                      "question": "常用的进针方法有（）、（）、（）、（）",
                      "answer": null,
                      "options": [],
                      "explanation": null,
                      "tags": [],
                      "id": "item-456"
                    },
                    {
                      "type": "table",
                      "headers": [
                        "方法名称",
                        "操作步骤",
                        "适用情况",
                        "图示"
                      ],
                      "rows": [
                        [
                          "1. 指切进针法",
                          "左手拇指端切按在穴位旁边，右手持针，紧靠左手指甲面将针刺入。",
                          "临床最为常用，适用于短针进针。",
                          "图 11-26"
                        ],
                        [
                          "2. 夹持进针法",
                          "左手拇、示两指夹捏棉球，夹住针身下端（针尖露出 0.2 寸左右），左手将针尖对准穴位，右手持针柄垂直下压，两手协同进针。",
                          "适用于长针进针。",
                          "图 11-27"
                        ],
                        [
                          "3. 提捏进针法",
                          "左手拇、示两指捏起针刺部位的皮肤，右手持针从捏起部位上端刺入。",
                          "适用于皮肉浅薄部位（如面部）。",
                          "图 11-28"
                        ],
                        [
                          "4. 舒张进针法",
                          "左手拇、示指或中指将针刺部位的皮肤撑开绷紧，右手将针刺入。",
                          "适用于皮肤松弛或皱纹部位（如腹部）。",
                          "图 11-29"
                        ]
                      ],
                      "id": "item-457"
                    },
                    {
                      "type": "multiple_choice",
                      "years": [],
                      "question": "印堂的进针法应采用",
                      "answer": null,
