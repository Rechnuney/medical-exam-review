                  "id": "subtopic-auto-0",
                  "title": "未分类",
                  "knowledgePoints": [
                    {
                      "type": "qa",
                      "years": [
                        2016
                      ],
                      "question": "方剂组成变化形式不包括以下哪一项?",
                      "answer": "A．药物炮制变化B．药味加减变化C．药量加减变化D．剂型更换变化",
                      "options": [
                        {
                          "label": "A",
                          "text": "臣药"
                        },
                        {
                          "label": "B",
                          "text": "反佐药"
                        },
                        {
                          "label": "C",
                          "text": "君药"
                        },
